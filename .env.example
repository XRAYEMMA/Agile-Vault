# Tatum API key — get yours at https://dashboard.tatum.io
# Required for Sui RPC calls (balance check, execute transaction)
TATUM_API_KEY=your-tatum-api-key-here

# Walrus API key (optional for testnet publisher, leave blank if not needed)
WALRUS_API_KEY=

# PostgreSQL connection string — free tier at https://neon.tech
# Falls back to localhost:5432/agile-vault if not set
DATABASE_URL=postgresql://user:password@host:5432/agile-vault

# Network: testnet only (Sui testnet for hackathon)
SUI_NETWORK=testnet

# Server port (Render uses PORT env var automatically)
PORT=8787

# Frontend API base URL (for Vite dev server proxy)
VITE_API_BASE_URL=http://localhost:8787

# Tatum Sui RPC Gateway endpoint (required for hackathon compliance)
VITE_TATUM_SUI_RPC_URL=https://sui-testnet.gateway.tatum.io
